xecution_count":30},{"id":"a70cccfc-e614-4ec5-9db6-7a6ef536850f","cell_type":"code","source":"# Phase 1 — Train head only (5 epochs)\nEPOCHS_PHASE1 = 5\nbest_val_acc  = 0\nhistory       = []\n\nprint('Phase 1: Training classifier head only')\nfor epoch in range(EPOCHS_PHASE1):\n    tr_loss, tr_acc = train_epoch(model, train_loader)\n    vl_loss, vl_acc = val_epoch(model,   val_loader)\n    scheduler.step(vl_loss)\n    history.append((tr_loss, tr_acc, vl_loss, vl_acc))\n\n    if vl_acc > best_val_acc:\n        best_val_acc = vl_acc\n        torch.save(model.state_dict(), CKPT_PATH)\n\n    print(f'Epoch {epoch+1}/{EPOCHS_PHASE1} | '\n          f'Train Loss: {tr_loss:.4f} Acc: {tr_acc:.4f} | '\n          f'Val Loss: {vl_loss:.4f} Acc: {vl_acc:.4f}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-13T18:01:42.968187Z","iopub.execute_input":"2026-06-13T18:01:42.968747Z","iopub.status.idle":"2026-06-13T18:08:03.296046Z","shell.execute_reply.started":"2026-06-13T18:01:42.968719Z","shell.execute_reply":"2026-06-13T18:08:03.295047Z"}},"outputs":[{"name":"stdout","text":"Phase 1: Training classifier head only\nEpoch 1/5 | Train Loss: 1.5721 Acc: 0.5517 | Val Loss: 1.3348 Acc: 0.6011\nEpoch 2/5 | Train Loss: 1.3003 Acc: 0.5974 | Val Loss: 1.2382 Acc: 0.5891\nEpoch 3/5 | Train Loss: 1.2492 Acc: 0.5947 | Val Loss: 1.1849 Acc: 0.6470\nEpoch 4/5 | Train Loss: 1.1609 Acc: 0.6061 | Val Loss: 1.1508 Acc: 0.6375\nEpoch 5/5 | Train Loss: 1.1540 Acc: 0.6036 | Val Loss: 1.1119 Acc: 0.6405\n","output_type":"stream"}],"execution_count":31},{"id":"dd1b7a44-b4a3-4094-8f56-2d9bc24f98c3","cell_type":"code","source":"# Phase 2 — Unfreeze last block + fine-tune\nprint('Phase 2: Fine-tuning last block')\n\n# Unfreeze features block 6 and 7 (last two blocks)\nfor name, param in model.named_parameters():\n    if 'features.6' in name or 'features.7' in name or 'classifier' in name:\n        param.requires_grad = True\n\noptimizer = optim.Adam(\n    filter(lambda p: p.requires_g